# ──────────────────────────────────────────────────────────────
# Auth Bridge Example — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# MySQL (matches docker-compose.yml defaults)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=authbridge
DB_PASSWORD=authbridge
DB_NAME=auth_bridge

# Server wallet root key (32 bytes hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_WALLET_KEY=

# Auth Bridge encryption key for managed wallet root keys (32 bytes hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_BRIDGE_KEY=

# JWT secret for session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_BRIDGE_JWT_SECRET=

# BSV chain ('main' or 'test')
BSV_CHAIN=test

# Wallet-toolbox remote storage URL
STORAGE_URL=https://staging-storage.babbage.systems

# Backend port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (optional — leave blank to disable) ──────────
# Get these from https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend env (prefix with VITE_ for Vite) ────────────────
# Same Google client ID as above (the frontend needs it too)
VITE_GOOGLE_CLIENT_ID=
